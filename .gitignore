# Ignore everything by default.
*
!*/
!.gitignore
!README.md

# Allow Markdown documents.
!*.md
!**/*.md

# Allow image assets used by notes.
!*.png
!**/*.png
!*.jpg
!**/*.jpg
!*.jpeg
!**/*.jpeg
!*.gif
!**/*.gif
!*.webp
!**/*.webp
!*.svg
!**/*.svg
!*.bmp
!**/*.bmp
!*.tif
!**/*.tif
!*.tiff
!**/*.tiff
!*.avif
!**/*.avif
!*.ico
!**/*.ico

# Ignore nested Git metadata; Note should not track nested repositories.
.git/
**/.git/
**/.git

# Ignore common generated and local files explicitly for clarity.
__pycache__/
node_modules/
.venv/
venv/
.wrangler/
.cache/
build/
dist/
*.log
*.tmp
*.temp

# Known local Git checkouts currently stored under notes.
**/darknet/
**/yolov5/
